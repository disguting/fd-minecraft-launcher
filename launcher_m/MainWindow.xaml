<ui:FluentWindow x:Class="launcher_m.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:launcher_m"
                 Title="Minecraft Launcher" 
                 MinHeight="750" MinWidth="950" 
                 Height="750" Width="950"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="None"
                 RenderOptions.BitmapScalingMode="HighQuality">

    <Grid>

        <Grid x:Name="AnimatedBackgroundLayer" Panel.ZIndex="-10" Background="#FF060807" IsHitTestVisible="False" ClipToBounds="True">

            <Canvas>
                <Ellipse Width="900" Height="900" Margin="-450,-450,0,0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF0A2614" Offset="0.0" />
                            <GradientStop Color="#000A2614" Offset="1.0" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="Blob1Transform" X="200" Y="200"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse Width="1000" Height="800" Margin="-500,-400,0,0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF0E331B" Offset="0.0" />
                            <GradientStop Color="#000E331B" Offset="1.0" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="Blob2Transform" X="800" Y="600"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse Width="800" Height="800" Margin="-400,-400,0,0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF081A0F" Offset="0.0" />
                            <GradientStop Color="#00081A0F" Offset="1.0" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="Blob3Transform" X="400" Y="300"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Canvas>

            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="Blob1Transform" Storyboard.TargetProperty="X" From="200" To="600" Duration="0:1:30" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="Blob1Transform" Storyboard.TargetProperty="Y" From="200" To="400" Duration="0:1:45" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>

                            <DoubleAnimation Storyboard.TargetName="Blob2Transform" Storyboard.TargetProperty="X" From="800" To="300" Duration="0:1:40" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="Blob2Transform" Storyboard.TargetProperty="Y" From="600" To="150" Duration="0:1:20" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>

                            <DoubleAnimation Storyboard.TargetName="Blob3Transform" Storyboard.TargetProperty="X" From="400" To="800" Duration="0:1:25" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="Blob3Transform" Storyboard.TargetProperty="Y" From="300" To="600" Duration="0:1:50" AutoReverse="True" RepeatBehavior="Forever">
                                <DoubleAnimation.EasingFunction>
                                    <SineEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>

        <Grid Panel.ZIndex="100">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="85"/>
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0" Title="Minecraft Launcher" />

            <Grid x:Name="NavContainer" Grid.Row="1" Margin="0,0,0,0">
                <ui:NavigationView x:Name="RootNavigation" 
                                   Background="Transparent"
                                   PaneDisplayMode="Top" 
                                   Transition="None"         
                                   TransitionDuration="0"    
                                   SelectionChanged="RootNavigation_SelectionChanged"
                                   SizeChanged="RootNavigation_SizeChanged">

                    <ui:NavigationView.Resources>
                        <SolidColorBrush x:Key="NavigationViewItemSelectionIndicatorForeground" Color="Transparent"/>
                        <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="Transparent"/>
                        <SolidColorBrush x:Key="NavigationViewSelectionIndicator" Color="Transparent"/>
                    </ui:NavigationView.Resources>

                    <ui:NavigationView.MenuItems>
                        <ui:NavigationViewItem Content="{DynamicResource Loc_NavHome}" TargetPageType="{x:Type local:HomeView}" Margin="35,0,0,0">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="Home24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>

                        <ui:NavigationViewItem Content="{DynamicResource Loc_NavCreateVersion}" TargetPageType="{x:Type local:BuilderView}">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="Add24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>

                        <ui:NavigationViewItem Content="{DynamicResource Loc_NavAccounts}" TargetPageType="{x:Type local:AccountsView}">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="Person24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationView.MenuItems>

                    <ui:NavigationView.FooterMenuItems>
                        <ui:NavigationViewItem Content="{DynamicResource Loc_NavSettings}" TargetPageType="{x:Type local:SettingsView}">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="Settings24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationView.FooterMenuItems>
                </ui:NavigationView>

                <Border x:Name="AnimatedSelectionLine" 
                        Height="3" 
                        Width="30"
                        Opacity="0"
                        Background="#FF4CAF50" 
                        VerticalAlignment="Top" 
                        HorizontalAlignment="Left" 
                        Margin="0,33,0,0" 
                        CornerRadius="1.5"
                        IsHitTestVisible="False">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="SelectionLineTransform" />
                    </Border.RenderTransform>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#08FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0">
                <Grid Margin="30,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,35,0">
                        <Border Width="42" Height="42" CornerRadius="21" Background="#1AFFFFFF" Margin="0,0,15,0">
                            <ui:SymbolIcon Symbol="Person24" Foreground="#FFCCCCCC"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Loc_PlayerLabel}" FontSize="12" Foreground="#FF888888" Margin="0,0,0,2"/>
                            <TextBlock x:Name="TxtActiveUsername" Text="{DynamicResource Loc_NotSelected}" FontSize="16" FontWeight="SemiBold" Foreground="White" MaxWidth="250" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon x:Name="IconSelectedInstance" Symbol="Box24" FontSize="26" Foreground="#FF888888" Margin="0,0,15,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Loc_SelectedVersionLabel}" FontSize="12" Foreground="#FF888888" Margin="0,0,0,2"/>
                            <TextBlock x:Name="TxtActiveInstance" Text="{DynamicResource Loc_NotSelected}" FontSize="16" FontWeight="SemiBold" Foreground="White" MaxWidth="300" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="LaunchProgressPanel" Grid.Column="2" VerticalAlignment="Center" Margin="30,0" Visibility="Collapsed">
                        <TextBlock x:Name="TxtLaunchStatus" Text="{DynamicResource Loc_PreparingToLaunch}" FontSize="12" Foreground="#FFAAAAAA" Margin="0,0,0,6" TextTrimming="CharacterEllipsis"/>
                        <ProgressBar x:Name="PbLaunchProgress" Height="4" Maximum="100" Value="0" Foreground="#FF4CAF50" Background="#1AFFFFFF"/>
                    </StackPanel>

                    <ui:Button Grid.Column="3" 
                               x:Name="BtnPlay"
                               Content="{DynamicResource Loc_PlayButton}" 
                               Appearance="Primary" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Padding="45,15" 
                               VerticalAlignment="Center"
                               Click="BtnPlay_Click"/>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="AlertOverlay" Visibility="Collapsed" Background="#C0000000" Panel.ZIndex="1000">
            <Border Background="#FF1E1E1E" CornerRadius="12" BorderBrush="#33FFFFFF" BorderThickness="1" 
                    VerticalAlignment="Center" HorizontalAlignment="Center" Width="420" Padding="30">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <ui:SymbolIcon Symbol="Warning24" FontSize="28" Foreground="#FFFFC107" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Loc_Warning}" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock x:Name="TxtAlertMessage" Text="{DynamicResource Loc_ErrorFallback}" Foreground="#FFDDDDDD" FontSize="14" LineHeight="20" Margin="0,0,0,30" TextWrapping="Wrap"/>

                    <ui:Button Content="{DynamicResource Loc_Understood}" Appearance="Primary" HorizontalAlignment="Stretch" Height="42" FontSize="15" FontWeight="SemiBold" Click="BtnCloseAlert_Click"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</ui:FluentWindow>