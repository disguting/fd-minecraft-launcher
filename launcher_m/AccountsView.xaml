<UserControl x:Class="launcher_m.AccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Foreground="{DynamicResource AppTextBrush}"
             Opacity="0">

    <UserControl.RenderTransform>
        <TranslateTransform Y="20"/>
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <QuarticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <QuarticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <UserControl.Resources>
        <Style x:Key="CleanListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,14,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="Transparent">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid Margin="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5.5*"/>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{DynamicResource Loc_ManageAccounts}" FontSize="28" FontWeight="Bold" Margin="0,0,0,20" Foreground="{DynamicResource AppTextBrush}"/>

                <ui:ListView x:Name="ListAccounts" 
                             Grid.Row="1" 
                             Background="Transparent" 
                             BorderThickness="0" 
                             Margin="-10,0,0,0" 
                             SelectionChanged="ListAccounts_SelectionChanged"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource CleanListViewItemStyle}"
                             VirtualizingPanel.IsVirtualizing="True" 
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.CanContentScroll="True">
                    <ui:ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Border x:Name="CustomSelection" Background="Transparent" BorderThickness="1" BorderBrush="Transparent" CornerRadius="8"/>
                                <Border Padding="12" Background="Transparent" HorizontalAlignment="Stretch">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="{DynamicResource AppCardBackgroundBrush}" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <ui:SymbolIcon FontSize="20" Foreground="{DynamicResource AppTextBrush}" Opacity="0.7">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Symbol" Value="Person24"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOffline}" Value="False">
                                                                <Setter Property="Symbol" Value="ShieldCheckmark24"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
                                                                <Setter Property="Opacity" Value="1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Username}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}"/>
                                            <TextBlock FontSize="12" Margin="0,2,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Microsoft Account"/>
                                                        <Setter Property="Foreground" Value="#FF03A9F4"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOffline}" Value="True">
                                                                <Setter Property="Text" Value="{DynamicResource Loc_OfflineAccountLabel}"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
                                                                <Setter Property="Opacity" Value="0.6"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CustomSelection" Property="Background" Value="{DynamicResource AppCardBackgroundBrush}"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}" Value="True">
                                    <Setter TargetName="CustomSelection" Property="Background" Value="{DynamicResource AppCardBackgroundBrush}"/>
                                    <Setter TargetName="CustomSelection" Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ui:ListView.ItemTemplate>
                </ui:ListView>
            </Grid>

            <StackPanel Grid.Column="2">
                <TextBlock Text="{DynamicResource Loc_Actions}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" Foreground="{DynamicResource AppTextBrush}"/>

                <ui:Button x:Name="BtnAddMicrosoft" 
                           Content="{DynamicResource Loc_AddMicrosoftAccount}" 
                           Icon="{ui:SymbolIcon PersonAdd24}" 
                           Appearance="Primary" 
                           Background="{DynamicResource AppButtonBrush}"
                           HorizontalAlignment="Stretch" 
                           Height="50" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,15"
                           Click="BtnAddMicrosoft_Click"/>

                <ui:Button Content="{DynamicResource Loc_AddOfflineAccount}" 
                           Icon="{ui:SymbolIcon PersonAdd24}" 
                           Appearance="Secondary" 
                           HorizontalAlignment="Stretch" 
                           Height="50" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,15" 
                           Click="BtnShowOfflineDialog_Click"/>

                <Separator Background="{DynamicResource AppCardBorderBrush}" Margin="0,10,0,25"/>

                <ui:Button Content="{DynamicResource Loc_DeleteSelected}" 
                           Icon="{ui:SymbolIcon Delete24}" 
                           Appearance="Danger" 
                           HorizontalAlignment="Stretch" 
                           Height="50" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Click="BtnDelete_Click"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="OfflineDialogOverlay" Visibility="Collapsed" Background="{DynamicResource AppOverlayBrush}" Canvas.ZIndex="100">
            <Border Background="{DynamicResource AppModalBackgroundBrush}" CornerRadius="12" BorderBrush="{DynamicResource AppCardBorderBrush}" BorderThickness="1" 
                    VerticalAlignment="Center" HorizontalAlignment="Center" Width="450" Padding="30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{DynamicResource Loc_NewOfflineAccount}" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" Foreground="{DynamicResource AppTextBrush}"/>

                    <StackPanel Grid.Row="1" Margin="0,5,0,25">
                        <TextBlock Text="{DynamicResource Loc_PlayerNameLabel}" Foreground="{DynamicResource AppTextBrush}" Opacity="0.6" Margin="0,0,0,5"/>
                        <ui:TextBox x:Name="txtOfflineUsername" PlaceholderText="{DynamicResource Loc_EnterNickname}" Height="40" Margin="0,0,0,20"/>

                        <Border Background="{DynamicResource AppCardBackgroundBrush}" BorderBrush="{DynamicResource AppCardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
                            <TextBlock Foreground="{DynamicResource AppTextBrush}" Opacity="0.9" FontSize="13" TextWrapping="Wrap" LineHeight="20">
                                <Run Text="{DynamicResource Loc_ImportantWarning}" FontWeight="Bold" Foreground="#FFFFC107"/>
                                <Run Text="{DynamicResource Loc_OfflineWarningDesc}"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0" Content="{DynamicResource Loc_Cancel}" HorizontalAlignment="Stretch" Height="42" FontSize="15" FontWeight="SemiBold" Click="BtnCloseOfflineDialog_Click"/>
                        <ui:Button Grid.Column="2" Content="{DynamicResource Loc_Save}" Appearance="Primary" Background="{DynamicResource AppButtonBrush}" HorizontalAlignment="Stretch" Height="42" FontSize="15" FontWeight="SemiBold" Click="BtnSaveOffline_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="AlertOverlay" Visibility="Collapsed" Background="{DynamicResource AppOverlayBrush}" Canvas.ZIndex="100">
            <Border Background="{DynamicResource AppModalBackgroundBrush}" CornerRadius="12" BorderBrush="{DynamicResource AppCardBorderBrush}" BorderThickness="1" 
                    VerticalAlignment="Center" HorizontalAlignment="Center" Width="420" Padding="30">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <ui:SymbolIcon Symbol="Warning24" FontSize="28" Foreground="#FFFFC107" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Loc_Warning}" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}"/>
                    </StackPanel>

                    <TextBlock x:Name="TxtAlertMessage" Text="{DynamicResource Loc_ErrorText}" Foreground="{DynamicResource AppTextBrush}" Opacity="0.9" FontSize="14" Margin="0,0,0,30" TextWrapping="Wrap" LineHeight="20"/>

                    <ui:Button Content="{DynamicResource Loc_Understood}" Appearance="Primary" Background="{DynamicResource AppButtonBrush}" HorizontalAlignment="Stretch" Height="42" FontSize="15" FontWeight="SemiBold" Click="BtnCloseAlert_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="DeleteConfirmOverlay" Visibility="Collapsed" Background="{DynamicResource AppOverlayBrush}" Canvas.ZIndex="100">
            <Border Background="{DynamicResource AppModalBackgroundBrush}" CornerRadius="12" BorderBrush="{DynamicResource AppCardBorderBrush}" BorderThickness="1" 
                    VerticalAlignment="Center" HorizontalAlignment="Center" Width="420" Padding="30">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <ui:SymbolIcon Symbol="Delete24" FontSize="28" Foreground="#FFF44336" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Loc_DeleteAccountTitle}" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource AppTextBrush}"/>
                    </StackPanel>

                    <TextBlock x:Name="TxtDeleteMessage" Text="{DynamicResource Loc_ConfirmDeleteAccount}" Foreground="{DynamicResource AppTextBrush}" Opacity="0.9" FontSize="14" Margin="0,0,0,30" TextWrapping="Wrap" LineHeight="20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0" Content="{DynamicResource Loc_Cancel}" HorizontalAlignment="Stretch" Height="42" FontSize="15" FontWeight="SemiBold" Click="BtnCancelDelete_Click"/>
                        <ui:Button Grid.Column="2" Content="{DynamicResource Loc_Delete}" Appearance="Danger" HorizontalAlignment="Stretch" Height="42" FontSize="15" FontWeight="SemiBold" Click="BtnConfirmDelete_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>