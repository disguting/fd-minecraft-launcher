<Application x:Class="launcher_m.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="AppAccentBrush" Color="#FF4CAF50"/>

            <SolidColorBrush x:Key="AppTextBrush" Color="#FFFFFFFF"/>

            <SolidColorBrush x:Key="AppButtonBrush" Color="Gray"/>

            <SolidColorBrush x:Key="AppGradientBrush" Color="#FF0A2614"/>


            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FF060807"/>

            <SolidColorBrush x:Key="AppModalBackgroundBrush" Color="#FF1E1E1E"/>

            <SolidColorBrush x:Key="AppCardBackgroundBrush" Color="#0AFFFFFF"/>
            <SolidColorBrush x:Key="AppCardBorderBrush" Color="#15FFFFFF"/>
            <SolidColorBrush x:Key="AppOverlayBrush" Color="#C0000000"/>


            <StaticResource x:Key="SystemAccentColorPrimaryBrush" ResourceKey="AppAccentBrush"/>
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#20000000"/>
            <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="#40000000"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>