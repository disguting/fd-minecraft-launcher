<Application x:Class="launcher_m.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="SystemAccentColor">#D3D3D3</Color>

            <Color x:Key="SystemAccentColorLight1">#8E8E8E</Color>
            <Color x:Key="SystemAccentColorLight2">#757575</Color>
            <Color x:Key="SystemAccentColorLight3">#5C5C5C</Color>
            <Color x:Key="SystemAccentColorDark1">#454545</Color>
            <Color x:Key="SystemAccentColorDark2">#333333</Color>

            <SolidColorBrush x:Key="SystemAccentColorBrush" Color="{StaticResource SystemAccentColor}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>