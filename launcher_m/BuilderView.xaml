        <Grid x:Name="DeleteConfirmOverlay" Visibility="Collapsed" Background="#C0000000" Canvas.ZIndex="1000">
            <Border Background="#FF1E1E1E" CornerRadius="12" BorderBrush="#33FFFFFF" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="420" Padding="30">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <ui:SymbolIcon Symbol="Delete24" FontSize="28" Foreground="#FFF44336" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Loc_DeleteInstanceTitle}" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock x:Name="TxtDeleteMessage" Text="{DynamicResource Loc_ConfirmDeleteInstance}" Foreground="#FFDDDDDD" FontSize="14" Margin="0,0,0,30" TextWrapping="Wrap" LineHeight="20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0" Content="{DynamicResource Loc_Cancel}" HorizontalAlignment="Stretch" Height="42" FontSize="15" FontWeight="SemiBold" Click="BtnCancelDelete_Click"/>
                        <ui:Button Grid.Column="2" Content="{DynamicResource Loc_Delete}" Appearance="Danger" HorizontalAlignment="Stretch" Height="42" FontSize="15" FontWeight="SemiBold" Click="BtnConfirmDelete_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

