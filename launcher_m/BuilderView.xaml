                    <TextBlock x:Name="TxtAlertMessage" Text="{DynamicResource Loc_ErrorFallback}" Foreground="#FFDDDDDD" FontSize="14" Margin="0,0,0,30" TextWrapping="Wrap" LineHeight="20"/>
                    <ui:Button Content="{DynamicResource Loc_Understood}" Appearance="Primary" HorizontalAlignment="Stretch" Height="42" FontSize="15" FontWeight="SemiBold" Click="BtnCloseAlert_Click"/>
                </StackPanel>
            </Border>
        </Grid>

